model User {
  id                       String                       @id @default(uuid()) @db.Uuid
  email                    String                       @db.VarChar(320)
  emailNormalized          String                       @unique @db.VarChar(320)
  role                     Role
  name                     String?                      @db.VarChar(160)
  status                   UserStatus                   @default(ACTIVE)
  dataProvenance           DataProvenance               @default(LIVE)
  emailVerifiedAt          DateTime?                    @db.Timestamptz(3)
  lastLoginAt              DateTime?                    @db.Timestamptz(3)
  createdAt                DateTime                     @default(now()) @db.Timestamptz(3)
  updatedAt                DateTime                     @updatedAt @db.Timestamptz(3)
  credential               Credential?
  sessions                 Session[]
  passwordResetTokens      PasswordResetToken[]
  candidateProfile         CandidateProfile?
  employerProfile          EmployerProfile?
  companyMemberships       CompanyMembership[]
  claimRequests            CompanyClaimRequest[]        @relation("ClaimRequester")
  verificationRequests     CompanyVerificationRequest[] @relation("VerificationRequester")
  notifications            Notification[]
  userConsents             UserConsentEvent[]           @relation("ConsentOwner")
  privacyRequests          PrivacyRequest[]             @relation("PrivacyRequester")
  privacyChallenges        PrivacyIdentityChallenge[]
  conversationParticipants ConversationParticipant[]
  revealConfirmations      IdentityRevealConfirmation[]
  revealGrantsRevoked      IdentityRevealGrant[]        @relation("RevealGrantRevoker")
  messages                 Message[]
  contactRequestsMade      EmployerContactRequest[]
  ordersCreated            Order[]
  abuseReportsFiled        AbuseReport[]                @relation("AbuseReporter")
  abuseReportsAssigned     AbuseReport[]                @relation("AbuseAssignee")
  auditLogs                AuditLog[]
  salesLeadsOwned          SalesLead[]
  systemTasksOwned         SystemTask[]
  supportCasesRequested    SupportCase[]                @relation("SupportRequester")
  supportCasesAssigned     SupportCase[]                @relation("SupportAssignee")
  recruiterMandates        RecruiterMandate[]           @relation("MandateRecruiter")
  recruiterMandatesGranted RecruiterMandate[]           @relation("MandateGrantor")
  jobAssignmentsCreated    JobAssignment[]              @relation("JobAssignmentAssigner")
  taxRatesReviewed         TaxRateVersion[]             @relation("TaxRateReviewer")

  @@index([status, role])
  @@index([dataProvenance, status])
}

model Credential {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @db.Uuid
  passwordHash      String   @db.VarChar(255)
  algorithm         String   @db.VarChar(32)
  algorithmVersion  Int
  passwordChangedAt DateTime @db.Timestamptz(3)
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)
  user              User     @relation(fields: [userId], references: [id], onDelete: Restrict)
}

model Session {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @db.Uuid
  tokenHash         String    @unique @db.VarChar(64)
  expiresAt         DateTime  @db.Timestamptz(3)
  absoluteExpiresAt DateTime  @db.Timestamptz(3)
  createdAt         DateTime  @default(now()) @db.Timestamptz(3)
  rotatedAt         DateTime? @db.Timestamptz(3)
  revokedAt         DateTime? @db.Timestamptz(3)
  userAgent         String?   @db.VarChar(512)
  ipHash            String?   @db.VarChar(128)
  user              User      @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
}

model PasswordResetToken {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @db.Uuid
  tokenHash          String    @unique @db.VarChar(64)
  expiresAt          DateTime  @db.Timestamptz(3)
