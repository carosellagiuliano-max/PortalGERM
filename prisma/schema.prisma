model RecruiterMandate {
  id                   String                  @id @default(uuid()) @db.Uuid
  recruiterUserId      String                  @db.Uuid
  clientCompanyId      String                  @db.Uuid
  grantedByOwnerUserId String                  @db.Uuid
  status               RecruiterMandateStatus  @default(SCHEDULED)
  validFrom            DateTime                @db.Timestamptz(3)
  validTo              DateTime                @db.Timestamptz(3)
  revokedAt            DateTime?               @db.Timestamptz(3)
  reasonCode           String                  @db.VarChar(64)
  idempotencyKey       String                  @unique @db.VarChar(128)
  createdAt            DateTime                @default(now()) @db.Timestamptz(3)
  recruiter            User                    @relation("MandateRecruiter", fields: [recruiterUserId], references: [id], onDelete: Restrict)
  grantedByOwner       User                    @relation("MandateGrantor", fields: [grantedByOwnerUserId], references: [id], onDelete: Restrict)
  clientCompany        Company                 @relation(fields: [clientCompanyId], references: [id], onDelete: Restrict)
  jobs                 RecruiterMandateJob[]
  events               RecruiterMandateEvent[]

  @@index([recruiterUserId, clientCompanyId, status, validFrom, validTo])
}

model RecruiterMandateJob {
  recruiterMandateId String           @db.Uuid
  jobId              String           @db.Uuid
  recruiterMandate   RecruiterMandate @relation(fields: [recruiterMandateId], references: [id], onDelete: Restrict)
  job                Job              @relation(fields: [jobId], references: [id], onDelete: Restrict)

  @@id([recruiterMandateId, jobId])
  @@index([jobId])
}

model RecruiterMandateEvent {
  id                 String                    @id @default(uuid()) @db.Uuid
  recruiterMandateId String                    @db.Uuid
  kind               RecruiterMandateEventKind
  actorUserId        String                    @db.Uuid
  reasonCode         String?                   @db.VarChar(64)
  correlationId      String                    @db.VarChar(128)
  createdAt          DateTime                  @default(now()) @db.Timestamptz(3)
  recruiterMandate   RecruiterMandate          @relation(fields: [recruiterMandateId], references: [id], onDelete: Restrict)

  @@index([recruiterMandateId, createdAt])
}

model ContentPage {
  id                         String            @id @default(uuid()) @db.Uuid
  slug                       String            @unique @db.VarChar(220)
  locale                     String            @db.VarChar(16)
  type                       ContentPageType
  canonicalPath              String            @db.VarChar(500)
  dataProvenance             DataProvenance    @default(LIVE)
  currentPublishedRevisionId String?           @unique @db.Uuid
  createdAt                  DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt                  DateTime          @updatedAt @db.Timestamptz(3)
  currentPublishedRevision   ContentRevision?  @relation("PublishedContentRevision", fields: [currentPublishedRevisionId, id], references: [id, contentPageId], onDelete: Restrict)
  revisions                  ContentRevision[] @relation("ContentRevisions")
  events                     ContentEvent[]

  @@unique([canonicalPath, locale])
  @@unique([currentPublishedRevisionId, id])
  @@index([type, locale, dataProvenance])
}

model ContentRevision {
  id               String                @id @default(uuid()) @db.Uuid
  contentPageId    String                @db.Uuid
  revisionNumber   Int
  status           ContentRevisionStatus @default(DRAFT)
  title            String                @db.VarChar(220)
  excerpt          String                @db.VarChar(500)
  body             String                @db.Text
  heroMetadata     Json?
  authoredByUserId String                @db.Uuid
  contentHash      String                @db.VarChar(64)
  reviewedAt       DateTime?             @db.Timestamptz(3)
  publishedAt      DateTime?             @db.Timestamptz(3)
  createdAt        DateTime              @default(now()) @db.Timestamptz(3)
  contentPage      ContentPage           @relation("ContentRevisions", fields: [contentPageId], references: [id], onDelete: Restrict)
  publishedForPage ContentPage?          @relation("PublishedContentRevision")
  events           ContentEvent[]

  @@unique([contentPageId, revisionNumber])
  @@unique([contentPageId, contentHash])
  @@unique([id, contentPageId])
  @@index([status, publishedAt])
}

model ContentEvent {
  id                String           @id @default(uuid()) @db.Uuid
  contentPageId     String           @db.Uuid
  contentRevisionId String           @db.Uuid
  kind              ContentEventKind
  actorUserId       String           @db.Uuid
  reasonCode        String?          @db.VarChar(64)
  correlationId     String           @db.VarChar(128)
  createdAt         DateTime         @default(now()) @db.Timestamptz(3)
  contentPage       ContentPage      @relation(fields: [contentPageId], references: [id], onDelete: Restrict)
  contentRevision   ContentRevision  @relation(fields: [contentRevisionId, contentPageId], references: [id, contentPageId], onDelete: Restrict)

  @@index([contentPageId, createdAt])
  @@index([contentRevisionId, createdAt])
}

model SupportCase {
  id              String             @id @default(uuid()) @db.Uuid
  requesterUserId String             @db.Uuid
  companyId       String?            @db.Uuid
  category        SupportCategory
  priority        SupportPriority    @default(NORMAL)
  status          SupportCaseStatus  @default(OPEN)
  subject         String             @db.VarChar(200)
  description     String             @db.VarChar(3000)
  assigneeUserId  String?            @db.Uuid
  dueAt           DateTime           @db.Timestamptz(3)
  correlationId   String             @db.VarChar(128)
  createdAt       DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime           @updatedAt @db.Timestamptz(3)
  requester       User               @relation("SupportRequester", fields: [requesterUserId], references: [id], onDelete: Restrict)
  assignee        User?              @relation("SupportAssignee", fields: [assigneeUserId], references: [id], onDelete: Restrict)
  company         Company?           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  events          SupportCaseEvent[]

  @@index([status, priority, dueAt])
  @@index([assigneeUserId, status, dueAt])
  @@index([requesterUserId, createdAt])
}

model SupportCaseEvent {
  id            String               @id @default(uuid()) @db.Uuid
  supportCaseId String               @db.Uuid
  kind          SupportCaseEventKind
  actorUserId   String               @db.Uuid
  safeBody      String?              @db.VarChar(3000)
  reasonCode    String?              @db.VarChar(64)
  correlationId String               @db.VarChar(128)
  createdAt     DateTime             @default(now()) @db.Timestamptz(3)
  supportCase   SupportCase          @relation(fields: [supportCaseId], references: [id], onDelete: Restrict)

  @@index([supportCaseId, createdAt])
}
