{
  "name": "swisstalenthub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": "24.18.0",
    "npm": "11.16.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "npm run db:generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:integration": "npm run env:validate && vitest run --config vitest.integration.config.ts",
    "test:e2e": "tsx scripts/http-smoke.ts",
    "env:init": "tsx scripts/env-init.ts",
    "env:validate": "tsx scripts/validate-env.ts",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:migrate": "npm run env:validate && prisma migrate deploy",
    "db:migrate:dev": "tsx scripts/require-local-database.ts && prisma migrate dev",
    "db:seed": "npm run env:validate && tsx prisma/seed.ts",
    "db:smoke": "npm run env:validate && tsx scripts/db-smoke.ts",
    "db:studio": "tsx scripts/require-local-database.ts && prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@fontsource-variable/inter": "5.3.0",
    "@hookform/resolvers": "5.4.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@radix-ui/react-slot": "1.2.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.25.0",
    "next": "16.2.10",
    "next-themes": "0.4.6",
    "pg": "8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.82.0",
    "server-only": "0.0.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.13.3",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "dotenv": "17.4.2",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "jsdom": "29.1.1",
    "postcss": "8.5.20",
    "prisma": "7.8.0",
    "shadcn": "4.13.1",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "prisma@7.8.0": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true,
    "@prisma/engines@7.8.0": true,
    "fsevents@2.3.3": true
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "next@16.2.10": {
      "postcss": "$postcss"
    }
  }
}
