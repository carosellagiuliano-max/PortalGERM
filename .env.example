# Copying this file verbatim is intentionally invalid. Run `npm run env:init`.
APP_ENV=local
NODE_ENV=development
DATABASE_URL=postgresql://swisstalenthub:local-development-only@127.0.0.1:5434/swisstalenthub?schema=public
TEST_DATABASE_URL=postgresql://swisstalenthub_test:local-test-only@127.0.0.1:5435/swisstalenthub_test?schema=public
APP_URL=http://127.0.0.1:3000
NEXT_PUBLIC_APP_NAME=SwissTalentHub

# Exactly 32 random bytes encoded as base64.
SESSION_SECRET=REPLACE_WITH_BASE64_32_BYTES

# Comma-separated `version:base64-32-byte-key`; first version writes.
AUDIT_IP_HASH_KEYS=v1:REPLACE_WITH_BASE64_32_BYTES
RADAR_OPAQUE_LOOKUP_KEYS=v1:REPLACE_WITH_BASE64_32_BYTES
RADAR_OPAQUE_ENCRYPTION_KEYS=v1:REPLACE_WITH_BASE64_32_BYTES
REVEAL_CONFIRMATION_KEYS=v1:REPLACE_WITH_BASE64_32_BYTES
PII_REVEAL_KEYS=v1:REPLACE_WITH_BASE64_32_BYTES

# Shared PostgreSQL is mandatory in Staging/Production. Memory is local/test only.
RATE_LIMIT_BACKEND=postgres

# Guarded local mailbox. Keep disabled unless a local test explicitly needs it.
ENABLE_LOCAL_MOCK_MAILBOX=false
DEV_MAILBOX_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS

LOG_LEVEL=info

# Phase-18 Ops values. Identity key material stays outside this repository.
BACKUP_AGE_RECIPIENT=
BACKUP_AGE_IDENTITY_FILE=

# Inactive future-provider placeholders. Leave empty for the mock-only MVP.
STRIPE_SECRET_KEY=
EMAIL_PROVIDER_API_KEY=
OPENAI_API_KEY=
STORAGE_ENDPOINT=
JOBROOM_API_URL=
MAPS_API_KEY=
